rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Inscrições: qualquer visitante pode ENVIAR uma inscrição (formulário público),
    // mas só a staff logada pode ler, aprovar/rejeitar ou excluir.
    match /inscricoes/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Demais coleções (torneios, times, partidas, notícias):
    // leitura pública para o site, escrita só para quem está logado no painel admin.
    match /{collection}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
