rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Leitura pública para o site (torneios, times, partidas, notícias)
    // Escrita só para usuários autenticados (login do painel admin)
    match /{collection}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
